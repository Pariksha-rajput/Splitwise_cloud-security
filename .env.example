# Fairsplit — App Configuration
# Copy this file to .env and fill in your values.
# This file is safe to commit. .env is gitignored.

# ── Flask ──────────────────────────────────────────────────────────────────────
SECRET_KEY=fairsplit_super_secret_key_change_me

# ── Database ───────────────────────────────────────────────────────────────────
# Local development (SQLite — no setup needed, file created automatically)
DATABASE_URL=sqlite:///fairsplit.db

# Azure production (PostgreSQL Flexible Server)
# Get <postgresql_host> from: terraform output postgresql_host
# DATABASE_URL=postgresql://fairsplitadmin:<password>@<postgresql_host>:5432/fairsplit

# ── Email / SMTP (optional) ────────────────────────────────────────────────────
# Without these, email notifications are disabled but the app works fine.
# Gmail: use an App Password, not your normal password.
# Generate one at: https://myaccount.google.com/apppasswords
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=youraddress@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx
# SMTP_FROM=youraddress@gmail.com
