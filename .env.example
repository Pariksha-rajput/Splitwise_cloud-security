# Spiltwise Configuration
# Copy this to .env and fill in your values

SECRET_KEY=spiltwise_super_secret_key_change_me

# Local SQLite (default — no setup needed)
DATABASE_URL=sqlite:///spiltwise.db

# Azure PostgreSQL Flexible Server — use this when deploying to AKS
# DATABASE_URL=postgresql://splitwiseadmin:<password>@<postgresql_host>:5432/spiltwise
