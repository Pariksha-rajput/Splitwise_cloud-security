# Fairsplit Configuration
# Copy this to .env and fill in your values

SECRET_KEY=spiltwise_super_secret_key_change_me

# Local SQLite (default — no setup needed, file created automatically)
DATABASE_URL=sqlite:///spiltwise.db

# Azure PostgreSQL Flexible Server — use this when deploying to AKS
# Get <postgresql_host> from: terraform output postgresql_host
# DATABASE_URL=postgresql://splitwiseadmin:<password>@<postgresql_host>:5432/spiltwise

# Email — real mail goes to the same address you use to log in (your User.email).
# Without SMTP_* below, the app never connects to a mail server (OTPs/alerts stay in-app only).
#
# Gmail: create an App Password (not your normal password): https://support.google.com/accounts/answer/185833
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=youraddress@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx
# SMTP_FROM=youraddress@gmail.com
#set TF_VAR_db_password=Spiltwise@2024!    
